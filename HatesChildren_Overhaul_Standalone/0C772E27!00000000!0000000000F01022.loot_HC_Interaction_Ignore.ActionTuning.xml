          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>273819<!--trait_infant--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- Toddler gets Lonely -->
    <V t="buff">
      <U n="buff">
