                  <T>34316<!--trait_child--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- Relationship decay for all -->
    <V t="relationship">
      <V n="relationship" t="change">
        <U n="change">
          <T n="amount">-20</T>
          <E n="track">STR</E>
          <L n="subject"><E>Actor</E></L>
          <L n="target_participant_type"><E>TargetSim</E></L>
        </U>
      </V>
    </V>
    <V t="relationship">
      <V n="relationship" t="change">
        <U n="change">
          <T n="amount">-20</T>
          <E n="track">STR</E>
          <L n="subject"><E>TargetSim</E></L>
          <L n="target_participant_type"><E>Actor</E></L>
        </U>
      </V>
    </V>

