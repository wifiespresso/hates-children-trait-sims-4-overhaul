<?xml version="1.0" encoding="utf-8"?>
<!--
  SOCIAL MIXER INTERACTION: mixer_HC_ignore_any
  "Ignore"

  Available when a HatesChildren adult/YA targets any child, toddler, or infant.
  The HC sim turns away / looks at phone — dismissive, cold.
  The child receives age-appropriate Lumpinou sad mood.

  Outcome loot: loot_HC_Interaction_Ignore.
  This is the "passive" cruelty option — zero warmth, zero engagement.
-->
<I c="ImmediateSuperInteraction" i="interaction" m="interactions.base.immediate_interaction" n="mixer_HC_ignore_any" s="15732775">
  <L n="_super_interactions">
    <T>13195<!--socialSuperInteraction--></T>
    <T>14672<!--socialSuperInteraction_AlwaysOn--></T>
  </L>

  <V n="_asm_context_override" t="enabled">
    <T n="enabled">social_Ignore</T>
  </V>

  <T n="display_name">0xF0002003<!--"Ignore"--></T>
  <T n="pie_menu_tooltip">0xF0002013<!--"Look through the child as if they're not even there."--></T>

  <V n="pie_menu_category" t="enabled">
    <T n="enabled">90601<!--pie_category_mean--></T>
  </V>

  <V n="test_globals" t="enabled">
    <L n="enabled">
      <V t="trait">
        <U n="trait">
          <E n="subject">Actor</E>
          <L n="whitelist_traits">
            <T>16844<!--trait_HatesChildren--></T>
          </L>
        </U>
      </V>
      <V t="sim_info">
        <U n="sim_info">
          <V n="ages" t="specified">
            <L n="specified">
              <E>YOUNGADULT</E>
              <E>ADULT</E>
              <E>ELDER</E>
            </L>
          </V>
        </U>
      </V>
      <!-- Target can be child, toddler, or infant -->
      <V t="sim_info">
        <U n="sim_info">
          <E n="participant">TargetSim</E>
          <V n="ages" t="specified">
            <L n="specified">
              <E>CHILD</E>
              <E>TODDLER</E>
              <E>INFANT</E>
            </L>
          </V>
        </U>
      </V>
    </L>
  </V>

  <L n="basic_extras">
    <V t="loot">
      <U n="loot">
        <L n="loot_list">
          <T>15732770<!--loot_HC_Interaction_Ignore--></T>
        </L>
      </U>
    </V>
    <!-- Generic sad reaction push on target -->
    <V t="loot">
      <U n="loot">
        <L n="loot_list">
          <T>125126<!--loot_Reaction_Generic_Shocked--></T>
        </L>
        <E n="subject">TargetSim</E>
      </U>
    </V>
  </L>

  <V n="outcome" t="all_outcomes">
    <U n="all_outcomes">
      <V n="single_outcome" t="basic">
        <U n="basic">
          <T n="weight">1</T>
        </U>
      </V>
    </U>
  </V>

</I>
