<!--
  STANDALONE OVERRIDE: trait_HatesChildren (s=16844)

  Complete standalone replacement. Does NOT require Zuperbuu's mod.
  Incorporates all of Zuperbuu's game_effect_modifiers PLUS Tier 2 additions.

  What this does:
    - Pregnancy buff replacements (vanilla Maxis content preserved)
    - Proximity buff list (vanilla anger buffs around children)
    - Parenting skill gain = 0 (Zuperbuu)
    - Parenting stat advancement blocked at -100 (Zuperbuu)
    - Relationship score multipliers = 0 toward children (Zuperbuu)
    - Social motive score multiplier = 0 toward children (Zuperbuu)
    - FUN motive score multiplier = 0 toward children (Tier 2 NEW)
    - Commodity injection for ForcedCaregiver distressed buff (Tier 2 NEW)

  Compatible with Less Obsessive Parents (Tier 1) — no conflict.
  LOP patches Python autonomy, this patches XML trait tuning.
-->
<I c="Trait" i="trait" m="traits.traits" n="trait_HatesChildren" s="16844">
  <L n="ages">
    <E>TEEN</E>
    <E>ADULT</E>
    <E>ELDER</E>
    <E>YOUNGADULT</E>
  </L>
  <!-- Pregnancy buff replacements (Maxis vanilla) -->
  <L n="buff_replacements">
    <U>
      <T n="key">12561<!--buff_Pregnancy_Trimester1--></T>
      <U n="value">
        <T n="buff_type">97309<!--buff_Pregnancy_Trimester1_HatesChildren--></T>
      </U>
    </U>
    <U>
      <T n="key">12562<!--buff_Pregnancy_Trimester2--></T>
      <U n="value">
        <T n="buff_type">97310<!--buff_Pregnancy_Trimester2_HatesChildren--></T>
      </U>
    </U>
    <U>
      <T n="key">12563<!--buff_Pregnancy_Trimester3--></T>
      <U n="value">
        <T n="buff_type">97311<!--buff_Pregnancy_Trimester3_HatesChildren--></T>
      </U>
    </U>
    <U>
      <T n="key">271528<!--buff_FacialMask_Applied_Family_CTYAE--></T>
      <U n="value">
        <T n="buff_type">271530<!--buff_FacialMask_Applied_Family_HatesChildren--></T>
      </U>
    </U>
    <U>
      <T n="key">271531<!--buff_FacialMask_Applied_Family_CTYAE_ReadyToRemove--></T>
      <U n="value">
        <T n="buff_type">271534<!--buff_FacialMask_Applied_Family_HatesChildren_ReadyToRemove--></T>
      </U>
    </U>
    <U>
      <T n="key">351499</T>
      <U n="value">
        <T n="buff_type">355552</T>
      </U>
    </U>
  </L>
  <!-- Always-on trait buff (vanilla) -->
  <L n="buffs">
    <U>
      <T n="buff_type">76800<!--Buff_Trait_HatesChildren--></T>
    </U>
  </L>
  <!-- Proximity anger buffs when near children/toddlers/infants (vanilla) -->
  <L n="buffs_proximity">
    <T>74233<!--Buff_Trait_HatesChildren hidden anger near older children--></T>
    <T>157197<!--Buff_Trait_HatesToddlers hidden anger near toddlers--></T>
    <T>333376<!--Buff_Trait_HatesInfants anger near infants--></T>
  </L>
  <T n="cas_trait_asm_param">HatesChildren</T>
  <L n="conflicting_traits">
    <T>16838<!--trait_FamilyOriented--></T>
    <T>16830<!--trait_Childish--></T>
  </L>
  <T n="display_name">0x67D30046<!--Hates Children--></T>
  <T n="display_name_gender_neutral">0xF1A83C4E<!--Hates Children--></T>
  <T n="icon" p="InGame\UI\Icons\CAS\Traits\trait_hateschildren_cas.png">2f7d0004:00000000:ddc123abb83228aa</T>
  <V n="loot_on_trait_add" t="enabled">
    <L n="enabled">
      <T>201221<!--loot_Reputation_NPC_Trait_Bad_HatesChildren--></T>
    </L>
  </V>
  <E n="min_lod_value">MINIMUM</E>
  <L n="species">
    <E />
  </L>
  <L n="tags">
    <E>TraitPersonality</E>
    <E>TraitGroup_Social</E>
  </L>
  <T n="trait_description">0x88ACCC79</T>
  <E n="trait_type">PERSONALITY</E>
  <V n="ui_category" t="ui_trait_category_tag" />
  <V n="whim_set" t="enabled">
    <T n="enabled">34796<!--whimset_HasTraitHatesChildren--></T>
  </V>
  <U n="game_effect_modifier">
    <L n="_game_effect_modifiers">

      <!-- ══ BLOCK 1 (Zuperbuu): Parenting skill/stat zeroed ══ -->
      <V t="autonomy_modifier">
        <U n="autonomy_modifier">
          <L n="skill_tag_modifiers">
            <U>
              <E n="key">Skill_Parenting</E>
              <T n="value">0</T>
            </U>
          </L>
          <L n="stat_modifiers">
            <U>
              <T n="key">160504<!--statistic_Skill_AdultMajor_Parenting--></T>
              <T n="value">-100</T>
            </U>
          </L>
        </U>
      </V>

      <!-- ══ BLOCK 2 (Zuperbuu): Relationship/Social indifference toward children ══ -->
      <V t="autonomy_modifier">
        <U n="autonomy_modifier">
          <L n="relationship_score_multipliers">
            <U>
              <T n="key">155918<!--Caregiver Bit--></T>
              <T n="value">0</T>
            </U>
            <U>
              <T n="key">8805<!--Family Bit--></T>
              <T n="value">0</T>
            </U>
          </L>
          <V n="target_test_exempt_autonomy_modifiers" t="enabled">
            <L n="enabled">
              <V t="trait">
                <U n="trait">
                  <L n="whitelist_traits">
                    <T>34316<!--trait_child--></T>
                    <T>133125<!--trait_toddler--></T>
                    <T>273819<!--trait_infant--></T>
                  </L>
                </U>
              </V>
            </L>
          </V>
          <L n="score_multipliers">
            <U>
              <T n="key">16658<!--motive_Social--></T>
              <T n="value">0</T>
            </U>
          </L>
        </U>
      </V>

      <!-- ══ BLOCK 3 (Tier 2 NEW): Fun motive also zeroed toward children ══
           Closes the gap where an HC sim might still autonomously play with a
           toddler because their Fun need is low — Fun gain is now also suppressed
           when the target is a child/toddler/infant. -->
      <V t="autonomy_modifier">
        <U n="autonomy_modifier">
          <V n="target_test_exempt_autonomy_modifiers" t="enabled">
            <L n="enabled">
              <V t="trait">
                <U n="trait">
                  <L n="whitelist_traits">
                    <T>34316<!--trait_child--></T>
                    <T>133125<!--trait_toddler--></T>
                    <T>273819<!--trait_infant--></T>
                  </L>
                </U>
              </V>
            </L>
          </V>
          <L n="score_multipliers">
            <U>
              <T n="key">16655<!--motive_Fun--></T>
              <T n="value">0</T>
            </U>
          </L>
        </U>
      </V>

      <!-- ══ BLOCK 4 (Tier 2 NEW): ForcedCaregiver distressed buff commodity ══
           Adds our distressed uncomfortable buff as an available commodity while
           the trait is present. The actual APPLICATION is controlled by the
           loot tests in loot_HatesChildren_ApplyAllPenalties. -->
      <V t="autonomy_modifier">
        <U n="autonomy_modifier">
          <L n="commodities_to_add">
            <T>15732738<!--buff_HatesChildren_ForcedCaregiver_Distressed commodity--></T>
          </L>
        </U>
      </V>

    </L>
  </U>

  <!-- ══ HC CUSTOM INTERACTIONS: registered via trait ══
       These appear in the pie menu when the HC Sim right-clicks on a child/toddler/infant.
       ImmediateSuperInteraction types fire immediately (no queue). -->
  <L n="_sim_affordances">
    <T>15732773<!--mixer_HC_makeitknown_child--></T>
    <T>15732774<!--mixer_HC_dismiss_toddler--></T>
    <T>15732775<!--mixer_HC_ignore_any--></T>
    <T>15732789<!--mixer_HC_Discipline_Harsh_Toddler--></T>
  </L>
</I>
