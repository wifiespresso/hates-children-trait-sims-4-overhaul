<?xml version="1.0" encoding="utf-8"?>
<!--
  DISPATCHER: loot_HatesChildren_ApplyAllPenalties

  Standalone — no Zuperbuu dependency.
  REQUIRES: Lumpinou's Mood Pack Mod (for custom mood buffs).
  REQUIRES: Less Obsessive Parents (Tier 1 autonomy suppression).

  Called from:
    - loot_Infant_SetInfantConcern (care interactions)
    - loot_Infant_SetInfantConcern_InfantActor (reversed participant care)
    - loot_Cargivers_ToddlerBirthday (toddler birthday)
    - loot_Cargivers_BabyBirthday (infant birthday)
    - mixer_HC_makeitknown_child (new negative interaction)
    - mixer_HC_dismiss_toddler (new dismissive interaction)
    - mixer_HC_ignore_infant (new ignore interaction)

  Participant map depends on context — typically:
    Actor = care recipient (child/toddler/infant)
    TargetSim = caregiver (HC adult)

  ═══ SECTION 1: CAREGIVER CONSEQUENCES ═══
  Apply emotion to the HatesChildren caregiver (TargetSim).
  Uses Lumpinou Mood Pack buff IDs directly.

  ═══ SECTION 2: CHILD/TODDLER/INFANT REACTIONS ═══
  Apply age-appropriate Lumpinou mood to the care recipient (Actor).
  Layered on top of our own visible moodlet.
-->
<I c="LootActions" i="action" m="interactions.utils.loot" n="loot_HatesChildren_ApplyAllPenalties" s="15732739">
  <L n="loot_actions">

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 1: CAREGIVER EMOTIONS (applies to TargetSim = HC adult)
         Uses Lumpinou Overwhelmed for forced caregiving sessions.
         Uses Lumpinou Resentful for longer-term lingering emotion.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- 1a: Overwhelmed (Lumpinou MP) — triggers on ACTIVE caregiver role -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">14204977641661978557<!--Lumpinou_MP_Overwhelmed_Buff_CoreSocial--></T>
        </U>
        <E n="subject">TargetSim</E>
        <L n="tests">
          <L>
            <!-- Must have HatesChildren trait -->
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
            <!-- Must currently be in Active caregiver job -->
            <V t="situation_job_test">
              <U n="situation_job_test">
                <E n="subject">TargetSim</E>
                <L n="situation_jobs">
                  <T>275500<!--situationJob_Caregiver_Active--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- 1b: Resentful (Lumpinou MP) — triggers on any care interaction completion -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">18107140886631642177<!--Lumpinou_MP_Resentful_Buff_CoreSocial--></T>
        </U>
        <E n="subject">TargetSim</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- 1c: Vanilla tense buff (our own) — short visible moodlet for HC caregiver -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">15732737<!--buff_HatesChildren_PostInteraction_Tense--></T>
        </U>
        <E n="subject">TargetSim</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- 1d: Relationship decay — HC caregiver → child (−60 points) -->
    <V t="relationship_track">
      <U n="relationship_track">
        <V n="actor" t="actor">
          <U n="actor">
            <E n="participant">TargetSim</E>
          </U>
        </V>
        <V n="target" t="actor">
          <U n="actor">
            <E n="participant">Actor</E>
          </U>
        </V>
        <T n="relationship_track">16714</T>
        <T n="value">-60</T>
      </U>
    </V>

    <!-- 1e: Relationship decay — child → HC caregiver (−60 points, bidirectional) -->
    <V t="relationship_track">
      <U n="relationship_track">
        <V n="actor" t="actor">
          <U n="actor">
            <E n="participant">Actor</E>
          </U>
        </V>
        <V n="target" t="actor">
          <U n="actor">
            <E n="participant">TargetSim</E>
          </U>
        </V>
        <T n="relationship_track">16714</T>
        <T n="value">-60</T>
      </U>
    </V>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 2: INFANT REACTIONS (Actor = infant sim)
         Applies Lumpinou Neglected + our own Uncertain moodlet.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- 2a: Lumpinou Neglected — infant -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">17553962537445570346<!--Lumpinou_MP_Neglected_CoreSocial--></T>
        </U>
        <E n="subject">Actor</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
            <V t="trait">
              <U n="trait">
                <E n="subject">Actor</E>
                <L n="whitelist_traits">
                  <T>273819<!--trait_infant--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- 2b: Our custom Uncertain moodlet — infant -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">15732752<!--buff_HatesChildren_Infant_Uncertain--></T>
        </U>
        <E n="subject">Actor</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
            <V t="trait">
              <U n="trait">
                <E n="subject">Actor</E>
                <L n="whitelist_traits">
                  <T>273819<!--trait_infant--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 3: TODDLER REACTIONS (Actor = toddler sim)
         Applies Lumpinou Anxious + our own SomethingsWrong moodlet.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- 3a: Lumpinou Anxious — toddler -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">16323678634823409250<!--Lumpinou_MP_Anxious_Buff_CoreSocial--></T>
        </U>
        <E n="subject">Actor</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
            <V t="trait">
              <U n="trait">
                <E n="subject">Actor</E>
                <L n="whitelist_traits">
                  <T>133125<!--trait_toddler--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- 3b: Our custom SomethingsWrong moodlet — toddler -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">15732753<!--buff_HatesChildren_Toddler_SomethingsWrong--></T>
        </U>
        <E n="subject">Actor</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
            <V t="trait">
              <U n="trait">
                <E n="subject">Actor</E>
                <L n="whitelist_traits">
                  <T>133125<!--trait_toddler--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 4: CHILD REACTIONS (Actor = child sim)
         Applies Lumpinou Misunderstood + our own TheyDontLikeMe moodlet.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- 4a: Lumpinou Misunderstood — child -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">10030063784143251165<!--Lumpinou_MP_Misunderstood_Buff_CoreSocial--></T>
        </U>
        <E n="subject">Actor</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
            <V t="trait">
              <U n="trait">
                <E n="subject">Actor</E>
                <L n="whitelist_traits">
                  <T>34316<!--trait_child--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

    <!-- 4b: Our custom TheyDontLikeMe moodlet — child -->
    <V t="buff">
      <U n="buff">
        <U n="buff">
          <T n="buff_type">15732754<!--buff_HatesChildren_Child_TheyDontLikeMe--></T>
        </U>
        <E n="subject">Actor</E>
        <L n="tests">
          <L>
            <V t="trait">
              <U n="trait">
                <E n="subject">TargetSim</E>
                <L n="whitelist_traits">
                  <T>16844<!--trait_HatesChildren--></T>
                </L>
              </U>
            </V>
            <V t="trait">
              <U n="trait">
                <E n="subject">Actor</E>
                <L n="whitelist_traits">
                  <T>34316<!--trait_child--></T>
                </L>
              </U>
            </V>
          </L>
        </L>
      </U>
    </V>

  </L>
</I>

